# =============================================================================
#  ATS System — Environment Variables Template
#
#  INSTRUCTIONS:
#  1. Copy this file: cp .env.example .env
#  2. Fill in the values for your environment
#  3. The .env file is git-ignored — NEVER commit the actual .env file
#  4. For production, set these as real environment variables in your server
#     or container orchestration platform (e.g., Docker secrets, K8s secrets)
# =============================================================================

# ─── Spring Profile ──────────────────────────────────────────────────────────
# Options: dev | prod
# Use 'dev' for local development (relaxed DDL, verbose logging)
# Use 'prod' for production (strict Flyway validation, minimal logging)
SPRING_PROFILES_ACTIVE=dev

# ─── Database Configuration ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ats_db
DB_USERNAME=ats_user
DB_PASSWORD=your_secure_database_password_here

# ─── JWT Configuration ───────────────────────────────────────────────────────
# IMPORTANT: Generate a strong, random secret for production.
# Must be at least 256 bits (32 characters) for HMAC-SHA256.
# Generate one with: openssl rand -base64 64
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_minimum_256_bits_for_hmac_sha256

# Access token expiry: 3600000 ms = 1 hour
JWT_ACCESS_EXPIRY_MS=3600000

# Refresh token expiry: 604800000 ms = 7 days
JWT_REFRESH_EXPIRY_MS=604800000

# ─── Server Configuration ────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── File Upload Configuration ───────────────────────────────────────────────
# Directory where resume files are stored (relative or absolute path)
FILE_UPLOAD_DIR=uploads/resumes

# ─── CORS Configuration ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
